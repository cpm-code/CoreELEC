From bef6f4a80af1e30ad6f1d7f0aef06e3b96f24904 Mon Sep 17 00:00:00 2001
From: Portisch <hugo.portisch@yahoo.de>
Date: Thu, 14 Aug 2025 11:47:55 +0200
Subject: [PATCH 2/2] add rtl8733bs support

---
 hciattach_rtk.c | 6 ++++++
 rtb_fwc.c       | 8 +++++++-
 rtb_fwc.h       | 1 +
 3 files changed, 14 insertions(+), 1 deletion(-)

diff --git a/hciattach_rtk.c b/hciattach_rtk.c
index f3f5b32..e4af7c9 100644
--- a/hciattach_rtk.c
+++ b/hciattach_rtk.c
@@ -1789,6 +1789,9 @@ static int rtb_config(int fd, int proto, int speed, struct termios *ti)
 		} else if (rtb_cfg.hci_ver == 0x06 &&
 			 rtb_cfg.hci_rev == 0x000b) {
 			rtb_cfg.chip_type = CHIP_8723BS;
+		} else if (rtb_cfg.hci_ver == 0x0b &&
+			 rtb_cfg.hci_rev == 0x000f) {
+			rtb_cfg.chip_type = CHIP_8733BS;
 		} else {
 			RS_ERR("H4: unknown chip");
 			return -1;
@@ -1885,6 +1888,9 @@ static int rtb_config(int fd, int proto, int speed, struct termios *ti)
 	case CHIP_8852BS:
 		max_patch_size = 40 * 1024 + 529;
 		break;
+	case CHIP_8733BS:
+		max_patch_size = 0xC4Cf + 529; /* 49.2KB */
+		break;
 	default:
 		max_patch_size = 24 * 1024;
 		break;
diff --git a/rtb_fwc.c b/rtb_fwc.c
index 5e9e370..5ee5398 100644
--- a/rtb_fwc.c
+++ b/rtb_fwc.c
@@ -220,9 +220,13 @@ static struct patch_info patch_table[] = {
 		ROM_LMP_8723b, ROM_LMP_8723b, 8, 0x000d,
 		"rtl8723d_fw", "rtl8723d_config", "RTL8723DS"},
 	/* RTL8723FS */
-	{ RTL_FW_MATCH_HCI_VER | RTL_FW_MATCH_HCI_REV, CHIP_8723FS,
+	{ RTL_FW_MATCH_CHIP_TYPE | RTL_FW_MATCH_HCI_VER | RTL_FW_MATCH_HCI_REV, CHIP_8723FS,
 		ROM_LMP_8723b, ROM_LMP_8723b, 11, 0x000f,
 		"rtl8723fs_fw", "rtl8723fs_config", "RTL8723FS"},
+	/* RTL8733BS */
+	{ RTL_FW_MATCH_CHIP_TYPE | RTL_FW_MATCH_HCI_VER | RTL_FW_MATCH_HCI_REV, CHIP_8733BS,
+		ROM_LMP_8723b, ROM_LMP_8723b, 11, 0x000f,
+		"rtl8733bs_8723fs_fw", "rtl8733bs_8723fs_config", "RTL8733BS"},
 	/* add entries here*/

 	{ 0, 0, 0, ROM_LMP_NONE, 0, 0, "rtl_none_fw", "rtl_none_config", "NONE"}
@@ -505,6 +509,7 @@ static int is_mac(uint8_t chip_type, uint16_t offset)
 	case CHIP_8852AS:
 	case CHIP_8723FS:
 	case CHIP_8852BS:
+	case CHIP_8733BS:
 		if (offset == 0x0030)
 			return 1;
 		break;
@@ -535,6 +540,7 @@ static uint16_t get_mac_offset(uint8_t chip_type)
 	case CHIP_8852AS:
 	case CHIP_8723FS:
 	case CHIP_8852BS:
+	case CHIP_8733BS:
 		return 0x0030;
 	case 0: /* special for not setting chip_type */
 	case CHIP_8761AT:
diff --git a/rtb_fwc.h b/rtb_fwc.h
index 5e76c4b..a90f6f0 100644
--- a/rtb_fwc.h
+++ b/rtb_fwc.h
@@ -58,6 +58,7 @@ struct rtb_struct;
 #define CHIP_8852AS	0x75
 #define CHIP_8723FS	0x76
 #define CHIP_8852BS	0x77
+#define CHIP_8733BS	0x78

 #define RTL_FW_MATCH_CHIP_TYPE  (1 << 0)
 #define RTL_FW_MATCH_HCI_VER    (1 << 1)
--
2.43.0
