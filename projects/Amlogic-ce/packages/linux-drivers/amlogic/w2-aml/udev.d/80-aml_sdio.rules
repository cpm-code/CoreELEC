### Amlogic W2
### this driver is split in two individual kernel modules
ENV{MODALIAS}=="?*", ENV{SUBSYSTEM}=="sdio", ENV{SDIO_ID}=="1B8E:0640", GOTO="load_module"
GOTO="end"

LABEL="load_module"
ENV{MODALIAS}=="?*", ENV{SUBSYSTEM}=="sdio", RUN{builtin}+="kmod load w2_comm", RUN{builtin}+="kmod load w2"

LABEL="end"
