From f9abcf4ebcbbf2dcd8c2f4a9d55adb5d7242e9ab Mon Sep 17 00:00:00 2001
From: Peter <peter.vicman@gmail.com>
Date: Thu, 25 Dec 2025 17:00:00 +0100
Subject: [PATCH] fix pkgutil.get_loader() function for Python 3.14

function pkgutil.get_loader() (along with pkgutil.find_loader())
has been completely removed in Python 3.14
---
 pgi/overrides/__init__.py | 7 +++++--
 1 file changed, 5 insertions(+), 2 deletions(-)

diff --git a/pgi/overrides/__init__.py b/pgi/overrides/__init__.py
index 97451d9..77e056e 100644
--- a/pgi/overrides/__init__.py
+++ b/pgi/overrides/__init__.py
@@ -10,7 +10,6 @@ import sys
 import importlib
 import warnings
 from functools import wraps
-from pkgutil import get_loader
 
 from pgi import const
 from pgi.util import PyGIDeprecationWarning
@@ -108,7 +107,11 @@ def load_overrides(introspection_module):
 
         # http://bugs.python.org/issue14710
         try:
-            override_loader = get_loader(override_package_name)
+            spec = importlib.util.find_spec(override_package_name)
+            if spec is None:
+                override_loader = None
+            else:
+                override_loader = spec.loader
 
         except AttributeError:
             override_loader = None
-- 
