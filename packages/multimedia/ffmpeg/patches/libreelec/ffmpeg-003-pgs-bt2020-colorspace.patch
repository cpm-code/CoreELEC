-            YUV_TO_RGB1_CCIR_BT709(cb, cr);
+        /* PGS palettes are YCbCr + alpha. */
+        cb -= 128;
+        cr -= 128;
+
+        int use_mode = ctx->pgs_matrix;
+        if (use_mode == PGS_MATRIX_AUTO) {
+            /* Default to BT.709 colorspace. In case of <= 576 height use BT.601 */
+            use_mode = (avctx->height <= 0 || avctx->height > 576)
+                       ? PGS_MATRIX_BT709
+                       : PGS_MATRIX_BT601;
+        }
+
+        if (use_mode == PGS_MATRIX_BT2020) {
+            /* BT.2020 (non-constant luminance) */
+            r_add = ONE_HALF + FIX(1.4746  * 255.0 / 224.0) * cr;
+            g_add = ONE_HALF - FIX(0.16455 * 255.0 / 224.0) * cb
+                             - FIX(0.57135 * 255.0 / 224.0) * cr;
+            b_add = ONE_HALF + FIX(1.8814  * 255.0 / 224.0) * cb;
+        } else if (use_mode == PGS_MATRIX_BT709) {
+            /* BT.709 */
+            r_add = ONE_HALF + FIX(1.5748 * 255.0 / 224.0) * cr;
+            g_add = ONE_HALF - FIX(0.1873 * 255.0 / 224.0) * cb
+                             - FIX(0.4681 * 255.0 / 224.0) * cr;
