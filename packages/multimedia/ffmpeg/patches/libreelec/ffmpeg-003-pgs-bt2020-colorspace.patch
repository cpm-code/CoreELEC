+            g_add = ONE_HALF - FIX(0.344136 * 255.0 / 224.0) * cb
+                             - FIX(0.714136 * 255.0 / 224.0) * cr;
+            b_add = ONE_HALF + FIX(1.7720   * 255.0 / 224.0) * cb;
         }

