From 04df80f973b94f42209932c8f6be8b705819156c Mon Sep 17 00:00:00 2001
From: James Almer <jamrial@gmail.com>
Date: Thu, 11 Dec 2025 20:01:01 -0300
Subject: [PATCH] avcodec/cavs_parser: check return value of init_get_bits8

Fixes Coverity issue CID 1676035

Signed-off-by: James Almer <jamrial@gmail.com>
---
 libavcodec/cavs_parser.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/libavcodec/cavs_parser.c b/libavcodec/cavs_parser.c
index 882840cd7f84e..8dccc0923a83a 100644
--- a/libavcodec/cavs_parser.c
+++ b/libavcodec/cavs_parser.c
@@ -142,7 +142,8 @@ static int cavs_parse_frame(AVCodecParserContext *s, AVCodecContext *avctx,
             return 0;
         switch (stc) {
         case CAVS_START_CODE:
-            init_get_bits8(&gb, buf_ptr, buf_end - buf_ptr);
+            if (init_get_bits8(&gb, buf_ptr, buf_end - buf_ptr) < 0)
+                return 0;
             parse_seq_header(s, avctx, &gb);
             break;
         case PIC_I_START_CODE:
