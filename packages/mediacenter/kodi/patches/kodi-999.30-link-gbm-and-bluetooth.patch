From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CoreELEC build fix <noreply@coreelec.org>
Date: Wed, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH] cmake: link GBM and Bluetooth when used

Kodi's Amlogic windowing and GBM helpers call into libgbm, and TCPServer
uses BlueZ SDP APIs when Bluetooth is enabled. Ensure the corresponding
libraries are linked when available.
---
 xbmc/network/CMakeLists.txt          | 6 ++++++
 xbmc/windowing/amlogic/CMakeLists.txt | 6 ++++++
 xbmc/windowing/gbm/CMakeLists.txt     | 6 ++++++
 3 files changed, 18 insertions(+)

diff --git a/xbmc/network/CMakeLists.txt b/xbmc/network/CMakeLists.txt
index 0df44f3c28..6f7e2e6f0b 100644
--- a/xbmc/network/CMakeLists.txt
+++ b/xbmc/network/CMakeLists.txt
@@ -44,6 +44,12 @@ if(TARGET ${APP_NAME_LC}::MicroHttpd)
 endif()
 
 core_add_library(network)
+
+find_package(Bluetooth QUIET)
+if(TARGET ${APP_NAME_LC}::Bluetooth)
  target_link_libraries(${CORE_LIBRARY} PUBLIC ${APP_NAME_LC}::Bluetooth)
+endif()
 
 if(ENABLE_STATIC_LIBS AND ENABLE_UPNP)
   target_link_libraries(${CORE_LIBRARY} PRIVATE upnp)
 endif()
diff --git a/xbmc/windowing/amlogic/CMakeLists.txt b/xbmc/windowing/amlogic/CMakeLists.txt
index 2b5aa7b816..b6b1a91f39 100644
--- a/xbmc/windowing/amlogic/CMakeLists.txt
+++ b/xbmc/windowing/amlogic/CMakeLists.txt
@@ -13,3 +13,9 @@ if(TARGET ${APP_NAME_LC}::OpenGLES)
 endif()
 
 core_add_library(windowing_Amlogic)
+
+find_package(GBM QUIET)
+if(TARGET ${APP_NAME_LC}::GBM)
  target_link_libraries(${CORE_LIBRARY} PUBLIC ${APP_NAME_LC}::GBM)
+endif()
diff --git a/xbmc/windowing/gbm/CMakeLists.txt b/xbmc/windowing/gbm/CMakeLists.txt
index 4e0ae8fe66..99b04c8b06 100644
--- a/xbmc/windowing/gbm/CMakeLists.txt
+++ b/xbmc/windowing/gbm/CMakeLists.txt
@@ -23,3 +23,9 @@ if(TARGET ${APP_NAME_LC}::OpenGLES)
 endif()
 
 core_add_library(windowing_gbm)
+
+find_package(GBM QUIET)
+if(TARGET ${APP_NAME_LC}::GBM)
  target_link_libraries(${CORE_LIBRARY} PUBLIC ${APP_NAME_LC}::GBM)
+endif()
--
2.43.0
