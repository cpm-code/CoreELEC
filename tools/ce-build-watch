#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
ce-build-watch: start and/or monitor a CoreELEC build using .threads/*

Usage:
  tools/ce-build-watch --device <DEVICE> [--target release] [--start]
                     [--build-dir <path>] [--interval 2]
                     [--tail 120] [--follow-fail]

Examples:
  # Just monitor an existing build
  tools/ce-build-watch --device Amlogic-ng

  # Start a release build and monitor it
  tools/ce-build-watch --device Amlogic-ng --start

Notes:
  - Auto-detects the newest build.CoreELEC-<DEVICE>.* directory unless --build-dir is provided.
  - On failure, prints the failing job line(s) and tails the corresponding .threads/logs/<seq>.log.
EOF
}

DEVICE_ARG=""
TARGET="release"
START=0
INTERVAL=2
BUILD_DIR=""
TAIL_LINES=120
FOLLOW_FAIL=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--device)
      DEVICE_ARG="${2:-}"; shift 2;;
    -t|--target)
      TARGET="${2:-}"; shift 2;;
    --start)
      START=1; shift;;
    --build-dir)
      BUILD_DIR="${2:-}"; shift 2;;
    --interval)
      INTERVAL="${2:-}"; shift 2;;
    --tail)
      TAIL_LINES="${2:-}"; shift 2;;
    --follow-fail)
      FOLLOW_FAIL=1; shift;;
    -h|--help)
      usage; exit 0;;
    *)
      echo "Unknown arg: $1" >&2
      usage
      exit 2;;
  esac
done

DEVICE="${DEVICE_ARG:-${DEVICE:-}}"
if [[ -z "$DEVICE" ]]; then
  echo "Missing --device (or DEVICE env var)." >&2
  usage
  exit 2
fi

if ! [[ "$INTERVAL" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
  echo "--interval must be a number (seconds)." >&2
  exit 2
fi

strip_ansi() {
  # Strips common ANSI CSI sequences used in the dashboard.
  sed -r 's/\x1B\[[0-9;]*[A-Za-z]//g'
}

if [[ -z "$BUILD_DIR" ]]; then
  BUILD_DIR=$(ls -dt "build.CoreELEC-${DEVICE}."* 2>/dev/null | head -1 || true)
fi

if [[ -z "$BUILD_DIR" || ! -d "$BUILD_DIR" ]]; then
  echo "Could not find build dir for DEVICE=$DEVICE. Try --build-dir." >&2
  exit 2
fi

THREADS_DIR="$BUILD_DIR/.threads"
STATUS_FILE="$THREADS_DIR/status"
PROGRESS_FILE="$THREADS_DIR/progress"
LOG_DIR="$THREADS_DIR/logs"

if [[ $START -eq 1 ]]; then
  mkdir -p "$THREADS_DIR"
  ts=$(date +%Y%m%d-%H%M%S)
  run_log="$THREADS_DIR/make-${TARGET}-${ts}.log"
  exit_file="$THREADS_DIR/make-${TARGET}.exit"
  : >"$exit_file"

  echo "Starting: DEVICE=$DEVICE make $TARGET"
  echo "Logging:  $run_log"

  # Run in a subshell so we can capture the PID of the pipeline leader.
  (
    set +e
    DEVICE="$DEVICE" make "$TARGET" 2>&1 | tee "$run_log"
    rc=${PIPESTATUS[0]}
    echo "$rc" >"$exit_file" || true
    exit "$rc"
  ) &

  echo $! >"$THREADS_DIR/make-${TARGET}.pid"
fi

pid_file="$THREADS_DIR/make-${TARGET}.pid"
make_pid=""
if [[ -f "$pid_file" ]]; then
  make_pid=$(tr -d '[:space:]' < "$pid_file" || true)
fi

exit_file="$THREADS_DIR/make-${TARGET}.exit"

print_header() {
  local header="$1"
  echo
  echo "=== $header ==="
}

while true; do
  status_txt=""
  if [[ -f "$STATUS_FILE" ]]; then
    status_txt=$(cat "$STATUS_FILE" | strip_ansi || true)
  fi

  completed="0"
  if [[ -f "$PROGRESS_FILE" ]]; then
    completed=$(tr -d '[:space:]' < "$PROGRESS_FILE" 2>/dev/null || echo "0")
    completed=${completed:-0}
  fi

  total="?"
  elapsed="?"
  if [[ -n "$status_txt" ]]; then
    # Example: CoreELEC Dashboard (...) - 176 of 377 jobs completed, 00:01:10 elapsed
    if [[ "$status_txt" =~ -[[:space:]]*([0-9]+)[[:space:]]+of[[:space:]]+([0-9]+)[[:space:]]+jobs[[:space:]]+completed,[[:space:]]+([^[:space:]]+)[[:space:]]+elapsed ]]; then
      total="${BASH_REMATCH[2]}"
      elapsed="${BASH_REMATCH[3]}"
    fi
  fi

  # Clear screen (best-effort) and show a compact view.
  printf '\033[2J\033[H' || true
  echo "DEVICE=$DEVICE  BUILD_DIR=$BUILD_DIR"
  echo "Progress: ${completed}/${total}  Elapsed: ${elapsed}  (poll ${INTERVAL}s)"

  if [[ -n "$status_txt" ]]; then
    echo
    echo "Top jobs:"
    echo "$status_txt" | sed -n '2,20p'
  else
    echo
    echo "(No dashboard yet; waiting for $STATUS_FILE)"
  fi

  failed_lines=$(echo "$status_txt" | grep -E 'FAILED' || true)
  if [[ -n "$failed_lines" ]]; then
    print_header "BUILD FAILED"
    echo "$failed_lines"

    # Extract seq numbers from lines like: [02/183] FAILED install readline:target
    seqs=$(echo "$failed_lines" | sed -n -r 's/^\[[^/]*\/([0-9]+)\].*/\1/p' | sort -u)
    for seq in $seqs; do
      log_path="$LOG_DIR/${seq}.log"
      echo
      echo "Log: $log_path"
      if [[ -f "$log_path" ]]; then
        echo "--- tail -n $TAIL_LINES ---"
        tail -n "$TAIL_LINES" "$log_path" || true
        if [[ $FOLLOW_FAIL -eq 1 ]]; then
          echo
          echo "--- following $log_path (Ctrl-C to stop) ---"
          tail -f "$log_path"
        fi
      else
        echo "(log not found)"
      fi
    done

    exit 1
  fi

  if [[ -n "$make_pid" ]]; then
    if ! kill -0 "$make_pid" 2>/dev/null; then
      print_header "BUILD FINISHED"
      rc=""
      if [[ -f "$exit_file" ]]; then
        rc=$(tr -d '[:space:]' < "$exit_file" || true)
      fi

      if [[ -z "$rc" ]]; then
        echo "Process $make_pid is no longer running (exit code unknown)."
        exit 2
      fi

      if [[ "$rc" != "0" ]]; then
        echo "make $TARGET exited with code $rc."
        exit "$rc"
      fi

      echo "make $TARGET exited successfully."
      exit 0
    fi
  fi

  sleep "$INTERVAL"
done
